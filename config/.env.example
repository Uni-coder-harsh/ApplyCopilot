# ApplyCopilot environment config
# Copy this to .env and edit as needed
# .env is gitignored — never commit it

# ── App ────────────────────────────────────────────────────
APP_NAME=ApplyCopilot
DEBUG=false

# ── Auth (auto-generated on init, don't edit manually) ────
SECRET_KEY=change-me-before-first-run
TOKEN_EXPIRE_HOURS=720

# ── Ollama ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
MODEL_CLASSIFIER=phi3:mini
MODEL_REASONER=mistral:7b-instruct-q4_0
MODEL_EMBEDDER=nomic-embed-text

# ── Email sync ─────────────────────────────────────────────
EMAIL_SYNC_BATCH_SIZE=200
EMAIL_MAX_AGE_DAYS=365
